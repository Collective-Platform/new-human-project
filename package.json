{
  "name": "new-human-project",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:setup-local": "psql new_human_dev < scripts/setup-local-db.sql",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "db:seed-dev": "tsx src/db/seed-dev.ts",
    "db:reset-local": "dropdb new_human_dev && createdb new_human_dev && pnpm db:setup-local && pnpm db:migrate && pnpm db:seed && pnpm db:seed-dev",
    "db:seed": "tsx src/db/seed.ts",
    "content:new": "tsx scripts/new-content.ts",
    "content:check": "tsx scripts/check-content-ids.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "drizzle-orm": "^0.45.2",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "next-intl": "^4.9.1",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "swr": "^2.4.1",
    "ulid": "^3.0.2",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
